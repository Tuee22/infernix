.git
.gitignore
.data
.claude
.kube
.build
.build/*.dhall
.build/infernix-demo-*.dhall
build
build/*.dhall
build/infernix-demo-*.dhall

# Phase 8: operator-created runtime config, host manifest, and test config must
# never enter the image build context — otherwise a HostNative operator manifest
# leaks in and breaks build-time context detection (materialize-substrate then
# rejects linux-cpu/linux-gpu as "host-native"). The image bakes its own.
infernix.dhall
infernix-host.dhall
infernix.test.dhall

# Haskell build artifacts
dist-newstyle
.stack-work
cabal.project.local
cabal.project.local~
*.hi
*.o
*.dyn_hi
*.dyn_o
*.prof
*.aux
*.hp
*.eventlog

# Tooling and coverage output
coverage
.hpc
test-results
.tix
*.tix

# Frontend build artifacts
node_modules
web/node_modules
web/dist
web/output
web/.spago
web/spago.lock
web/package-lock.json
web/src/Generated
web/.parcel-cache
web/playwright-report
web/test-results
chart/charts
Chart.lock

# Python and generated artifacts
**/.mypy_cache
**/.ruff_cache
**/__pycache__
**/poetry.lock
python/.venv
python/engines/*/.venv
tools/generated_proto

# Temporary files
*.log
.DS_Store
tmp
.tmp
